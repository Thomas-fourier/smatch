#! /bin/bash

NR_CPU=`nproc`
SMATCH_DIR=$(dirname $(dirname $0))
CMD=$SMATCH_DIR/smatch
API_SPECS=$SMATCH_DIR/api_spec

find -name \*.c.smatch -exec rm \{\} \;

for file in  $(ls $API_SPECS); do
	dsl_files="$dsl_files --generic-args-file=$SMATCH_DIR/$file"
done

find . -type f -name "*.c" | sort | uniq | rev |\
	cut -d. -f2- |\
	rev | awk " {printf \$0 ; print \".o\" } " | \
	xargs make -j${NR_CPU} $ENDIAN -k CHECK="$CMD -p=kernel --file-output\
		--succeed $dsl_files" C=1 |\
	tee smatch.log


find -name \*.c.smatch -exec cat \{\} \; -exec rm \{\} \; |\
	grep -F -e "Possible function not matched"\
		-e "is the only of the interface"  >>\
			smatch.warning




