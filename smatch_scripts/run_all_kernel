#! /bin/bash

NR_CPU=`nproc`
CMD=$(dirname $(dirname $0))/smatch
API_SPECS=$(dirname $CMD)/api_spec

find -name \*.c.smatch -exec rm \{\} \;

TMP=$(mktemp)
func_name_list=$(mktemp)
files_to_run=$(mktemp)
headers=$(mktemp)
all_headers=$(mktemp)

c_files=$(mktemp)
h_files=$(mktemp)

find . -type f -name "*.c" >> $c_files
find . -type f -name "*.h" >> $h_files

rm -rf smatch_output
mkdir smatch_output

for file in  $(ls $API_SPECS)
	do
	echo $file
	# Extract function names
	cat $API_SPECS/$file | grep -v -E "^var[ \t]" | grep "(" | cut -d"(" -f 1 |\
		tr -d [:blank:] > $TMP
	cat $TMP | grep "=" | cut -d'=' -f 2 > $func_name_list
	cat $TMP | grep -v "=" >> $func_name_list
	true > $TMP

	# add every file in which is included previous files
	cat $c_files | xargs grep -f $func_name_list -l > $files_to_run
	cat $h_files | xargs grep -f $func_name_list -l |\
		xargs -r -n 1 basename > $headers
	
	cat $headers | sort > $all_headers

	while [ -s $headers ]
		do
		cat $c_files | xargs grep -f $headers -l >> $files_to_run
		cat $h_files | xargs grep -f $headers -l | xargs -r -n 1 basename |\
			sort | uniq | comm -13 $all_headers - > $TMP
		cat $TMP > $headers
		cat $headers  $all_headers | sort | uniq > $TMP
		cat $TMP > $all_headers
		true > $TMP
	done


	make clean

	cat $files_to_run | sort | uniq | rev |\
		cut -d. -f2- |\
		rev | awk " {printf \$0 ; print \".o\" } " | \
		xargs make -j${NR_CPU} $ENDIAN -k CHECK="$CMD -p=kernel --file-output\
			--succeed --generic-arg-file=$API_SPECS/$file" C=1 |\
		tee smatch_output/$file.log


	find -name \*.c.smatch -exec cat \{\} \; -exec rm \{\} \; |\
		grep "Possibly mixing" >> smatch_output/$file.warning
done

rm -f $TMP $func_name_list $files_to_run $headers $all_headers $c_files $h_files

find -name \*.c.smatch -exec cat \{\} \; -exec rm \{\} \; > smatch_warning.txt


